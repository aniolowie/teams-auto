# Microsoft Teams credentials
TEAMS_EMAIL=your_school_email@domain.edu
TEAMS_PASSWORD=your_password

# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Any model slug from https://openrouter.ai/models
OPENROUTER_MODEL=openai/gpt-4o

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
# Your personal Telegram chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=123456789
